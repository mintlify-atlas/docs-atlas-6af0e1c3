{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Repo Security Bot",
  "theme": "aspen",
  "colors": {
    "primary": "#848c8e",
    "light": "#11161e",
    "dark": "#cfd0d2"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "https://media.brand.dev/5ffd6ce4-2434-4b4b-920a-f8cacac8b48b.svg",
    "dark": "https://media.brand.dev/5ffd6ce4-2434-4b4b-920a-f8cacac8b48b.svg"
  },
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/arinagrawal05/repo-security-bot"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/arinagrawal05/repo-security-bot"
    }
